# ========================================
# 语音朗诵与文稿记录空间 - 全局环境配置
# ========================================
# 项目名称（容器名称前缀）
COMPOSE_PROJECT_NAME=recitation-space

# Docker 镜像仓库地址
# ⚠️ 国内公共镜像源已普遍失效，建议：
#   方案1（推荐）: 配置阿里云个人加速器（免费）
#          地址: https://cr.console.aliyun.com/
#          配置后在 Docker Desktop → Settings → Docker Engine 中添加
#          "registry-mirrors": ["https://xxx.mirror.aliyuncs.com"]
#   方案2: 有科学上网 → 留空直连 Docker Hub
#   方案3: 以下公共镜像可尝试（不保证可用）:
#          reg-mirror.qiniu.com/
#          docker.mirrors.ustc.edu.cn/
#          hub-mirror.c.163.com/
DOCKER_REGISTRY=

# ========================================
# 端口配置（全部自定义，避开默认端口）
# 固定端口表，禁止与其他项目复用
# ========================================
# 前端 Nginx 映射端口（避开 80/443/8080）
FRONTEND_PORT=18035

# 后端 API 映射端口（避开 8080/8081/9090）
BACKEND_PORT=19035

# MySQL 映射端口（避开 3306）
MYSQL_PORT=13335

# Redis 映射端口（避开 6379）
REDIS_PORT=16435

# ========================================
# MySQL 配置
# ========================================
MYSQL_ROOT_PASSWORD=recitation123
MYSQL_DATABASE=recitation_db
MYSQL_USER=recitation
MYSQL_PASSWORD=recitation123

# ========================================
# 时区配置
# ========================================
TZ=Asia/Shanghai
